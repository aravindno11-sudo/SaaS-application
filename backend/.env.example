# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# Local:   mongodb://localhost:27017/saas-db
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/saas-db
MONGODB_URI=mongodb://localhost:27017/saas-db

# ─── Auth ─────────────────────────────────────────────────
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ─── CORS ─────────────────────────────────────────────────
# Your deployed frontend URL (no trailing slash)
# Example: https://saas-docs.vercel.app
CORS_ORIGIN=http://localhost:5173

# ─── Stripe (leave as placeholder for mock mode) ──────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
